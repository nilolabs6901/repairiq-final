# RepairIQ Environment Variables
# Copy this file to .env.local and fill in your values

# Anthropic API (Claude AI) - Required
ANTHROPIC_API_KEY=your_anthropic_api_key

# NextAuth (Authentication) - Required
NEXTAUTH_SECRET=your_random_secret_string
NEXTAUTH_URL=http://localhost:3000

# YouTube Data API v3 (for repair videos) - Optional
YOUTUBE_API_KEY=your_youtube_api_key

# Base URL for API calls
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ElevenLabs Text-to-Speech (Premium Voice) - Optional
# Get your API key from https://elevenlabs.io
# Key format: sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Optional: Custom ElevenLabs voice ID (defaults to "Rachel" voice)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
